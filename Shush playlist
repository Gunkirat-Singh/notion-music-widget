<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            padding: 10px;
            background-color: #000000; /* Matches Notion Sidebar */
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            overflow: hidden;
        }

        .player-card {
            width: 100%;
            max-width: 260px;
            text-align: center;
        }

        /* The Square Album Art Frame */
        .art-container {
            width: 100%;
            aspect-ratio: 1 / 1;
            border-radius: 16px;
            overflow: hidden;
            position: relative;
            background: #111;
            border: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 12px;
        }

        /* The YouTube Video - Zoomed to fill the square */
        iframe {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 180%; /* Zoomed in to hide black bars */
            height: 180%;
            transform: translate(-50%, -50%);
            border: none;
            pointer-events: auto;
        }

        .song-info {
            padding: 5px 0;
        }

        .title {
            color: #FFFFFF;
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 2px;
            letter-spacing: -0.01em;
        }

        .subtitle {
            color: rgba(255, 255, 255, 0.4);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
    </style>
</head>
<body>

<div class="player-card">
    <div class="art-container">
        <iframe 
            src="https://www.youtube.com/embed/videoseries?list=PLuXBepVDtfVDfj6bYU3jb5f0bdqE-ljVU&modestbranding=1&rel=0&controls=1&showinfo=0&iv_load_policy=3" 
            allow="autoplay; encrypted-media">
        </iframe>
    </div>
    
    <div class="song-info">
        <div class="title">OS-Gunkirat Radio</div>
        <div class="subtitle">Focus Mode Active</div>
    </div>
</div>

</body>
</html>
