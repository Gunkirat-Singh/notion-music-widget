<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        body {
            margin: 0;
            background-color: #000000;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: white;
            overflow: hidden;
        }

        .player-card {
            width: 90%;
            max-width: 300px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            padding: 20px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* The Album Art Square */
        .art-container {
            width: 100%;
            aspect-ratio: 1 / 1;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            position: relative;
        }

        iframe {
            position: absolute;
            top: -50%; /* Hides the YouTube top bar */
            left: 0;
            width: 100%;
            height: 200%; /* Makes the video fill the square frame */
            border: none;
        }

        .song-info {
            margin-top: 10px;
        }

        .title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .subtitle {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* Aesthetic Play Indicator */
        .playing-bars {
            display: flex;
            justify-content: center;
            gap: 3px;
            margin-top: 15px;
            height: 15px;
        }

        .bar {
            width: 3px;
            background: white;
            border-radius: 3px;
            animation: bounce 1s ease-in-out infinite;
        }

        @keyframes bounce {
            0%, 100% { height: 5px; }
            50% { height: 15px; }
        }
    </style>
</head>
<body>

<div class="player-card">
    <div class="art-container">
        <iframe 
            src="https://www.youtube.com/embed/videoseries?list=PLuXBepVDtfVDfj6bYU3jb5f0bdqE-ljVU&modestbranding=1&rel=0&showinfo=0&controls=1&color=white" 
            allow="autoplay; encrypted-media">
        </iframe>
    </div>
    
    <div class="song-info">
        <div class="title">Focus Playlist</div>
        <div class="subtitle">Currently Streaming</div>
    </div>

    <div class="playing-bars">
        <div class="bar" style="animation-delay: 0.1s"></div>
        <div class="bar" style="animation-delay: 0.3s"></div>
        <div class="bar" style="animation-delay: 0.2s"></div>
        <div class="bar" style="animation-delay: 0.4s"></div>
    </div>
</div>

</body>
</html>
