<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #000000;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }
        /* This makes the player fit perfectly in your Notion sidebar */
        .video-container {
            width: 100%;
            height: 100%;
        }
        iframe {
            border: none;
            width: 100%;
            height: 100%;
        }
    </style>
</head>
<body>
    <div class="video-container">
        <iframe src="https://www.youtube.com/embed/videoseries?list=PLuXBepVDtfVDfj6bYU3jb5f0bdqE-ljVU&color=white&modestbranding=1&rel=0" 
                allow="autoplay; encrypted-media" 
                allowfullscreen>
        </iframe>
    </div>
</body>
</html>
